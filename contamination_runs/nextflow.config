/*
 * Config for standalone contamination-check runs.
 * Pass with: -c contamination_runs/nextflow.config
 */

docker.enabled = true

params {
    contamination_min_length  = 1000
    contamination_min_id      = 95
    contamination_hop_rate    = 0.001   // Expected index-hopping rate (0.1%)
    contamination_min_dir_ratio = 10.0  // Min cov ratio for high-confidence direction
    contamination_genome_size = 9500    // HCV genome size (bp) for hop threshold
    contamination_kmer_size   = 127     // SPAdes final k-mer size; converts k-mer cov to read depth (150bp → k=127 → ×24)
    contamination_min_aln_cov = 0.9     // Min fraction of shorter contig covered by BLAST alignment
}

process {
    withName: 'CONTAMINATION_CHECK:CONTIG_FILTER_RENAME' {
        publishDir = [
            path: { "${params.outdir}/contamination_check" },
            mode: 'copy',
            enabled: false
        ]
    }
    withName: 'CONTAMINATION_CHECK:CAT_FILTERED_CONTIGS' {
        publishDir = [
            path: { "${params.outdir}/contamination_check" },
            mode: 'copy',
            enabled: false
        ]
    }
    withName: 'CONTAMINATION_CHECK:BLAST_MAKEBLASTDB_CONTIGS' {
        ext.args = "-dbtype nucl"
        memory   = '4.GB'
        publishDir = [
            path: { "${params.outdir}/contamination_check" },
            mode: 'copy',
            enabled: false
        ]
    }
    withName: 'CONTAMINATION_CHECK:BLAST_BLASTN_CONTIGS' {
        ext.args   = { "-outfmt '6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore' -perc_identity ${params.contamination_min_id} -dust no" }
        ext.prefix = "all_samples_contigs"
        memory     = '8.GB'
        publishDir = [
            path: { "${params.outdir}/contamination_check" },
            mode: 'copy',
            enabled: false
        ]
    }
    withName: 'CONTAMINATION_CHECK:CONTAMINATION_REPORT' {
        ext.args = { "${params.contamination_hop_rate} ${params.contamination_min_dir_ratio} ${params.contamination_genome_size} ${params.contamination_kmer_size} ${params.contamination_min_aln_cov}" }
        publishDir = [
            path: { "${params.outdir}" },
            mode: 'copy'
        ]
    }
}
